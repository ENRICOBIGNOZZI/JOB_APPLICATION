# Local runtime flags. Copy to .env.local if needed. Do not commit real local files.

# Notifications are disabled by default. The repository does not send automatically.
JOB_AGENT_SEND_NOTIFICATIONS=0
JOB_AGENT_NOTIFY_TO=chiara.segala@usi.ch
JOB_AGENT_NOTIFY_FROM=local_review_only

# Local CV path expected by configs/profile.yaml
JOB_AGENT_CV_PATH=documents/cv_chiara_segala.pdf
